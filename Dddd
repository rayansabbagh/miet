#include <iostream>
#include <fstream>
#include <cmath>
#include <ctime>
#include <cstdlib>

using namespace std;

class Point {
private:
    float x;
    float y;

public:
    Point() {
        x = 0;
        y = 0;
    }

    Point(float x, float y) {
        this->x = x;
        this->y = y;
    }

    float getX() const { return x; }
    float getY() const { return y; }

    void setX(float x) { this->x = x; }
    void setY(float y) { this->y = y; }

    void print() const {
        cout << "(" << x << ", " << y << ")";
    }
};

class Circle {
private:
    Point center;
    float radius;

public:
    Circle() {
        center = Point(0, 0);
        radius = 1;
    }

    Circle(Point center, float radius) {
        this->center = center;
        if (radius > 0)
            this->radius = radius;
        else
            this->radius = 1;
    }

    Point getCenter() const { return center; }
    float getRadius() const { return radius; }

    void setCenter(Point center) { this->center = center; }

    void setRadius(float radius) {
        if (radius > 0)
            this->radius = radius;
    }

    float getLength() const {
        return 2.0f * 3.14159265f * radius;
    }

    void print() const {
        cout << "Center = ";
        center.print();
        cout << ", Radius = " << radius
             << ", Length = " << getLength() << endl;
    }

    static void sortByRadius(Circle arr[], int size, bool ascending) {
        for (int i = 0; i < size - 1; i++) {
            for (int j = 0; j < size - i - 1; j++) {
                bool needSwap;

                if (ascending)
                    needSwap = arr[j].getRadius() > arr[j + 1].getRadius();
                else
                    needSwap = arr[j].getRadius() < arr[j + 1].getRadius();

                if (needSwap) {
                    Circle temp = arr[j];
                    arr[j] = arr[j + 1];
                    arr[j + 1] = temp;
                }
            }
        }
    }
};

float rnd(float a, float b) {
    return a + (float)rand() / RAND_MAX * (b - a);
}

bool isPointOnCircle(const Point& p, const Circle& c) {
    float dx = p.getX() - c.getCenter().getX();
    float dy = p.getY() - c.getCenter().getY();
    float left = dx * dx + dy * dy;
    float right = c.getRadius() * c.getRadius();
    return fabs(left - right) < 0.0001f;
}

void saveData(const char* fileName, Circle staticArr[], Circle dynamicArr[], int n, const Point& p) {
    ofstream fout(fileName);
    if (!fout) {
        cout << "File error." << endl;
        return;
    }

    fout << n << endl;
    fout << p.getX() << " " << p.getY() << endl;

    for (int i = 0; i < n; i++) {
        fout << staticArr[i].getCenter().getX() << " "
             << staticArr[i].getCenter().getY() << " "
             << staticArr[i].getRadius() << endl;
    }

    for (int i = 0; i < n; i++) {
        fout << dynamicArr[i].getCenter().getX() << " "
             << dynamicArr[i].getCenter().getY() << " "
             << dynamicArr[i].getRadius() << endl;
    }

    fout.close();
    cout << "Data saved." << endl;
}

int main() {
    srand((unsigned)time(0));

    const int N = 6;
    Circle staticArr[N];
    Circle* dynamicArr = new Circle[N];
    Point p;

    for (int i = 0; i < N; i++) {
        staticArr[i] = Circle(Point(rnd(-10, 10), rnd(-10, 10)), rnd(1, 10));
        dynamicArr[i] = Circle(Point(rnd(-10, 10), rnd(-10, 10)), rnd(1, 10));
    }

    int index = rand() % N;
    Point c = staticArr[index].getCenter();
    float r = staticArr[index].getRadius();
    p = Point(c.getX() + r, c.getY());

    Circle::sortByRadius(staticArr, N, true);
    Circle::sortByRadius(dynamicArr, N, false);

    float value = 25.0f;

    cout << "Static array (length > " << value << "):" << endl;
    for (int i = 0; i < N; i++) {
        if (staticArr[i].getLength() > value)
            staticArr[i].print();
    }

    cout << endl;

    cout << "Dynamic array (length < " << value << "):" << endl;
    for (int i = 0; i < N; i++) {
        if (dynamicArr[i].getLength() < value)
            dynamicArr[i].print();
    }

    cout << endl;

    cout << "Point = ";
    p.print();
    cout << endl << endl;

    bool foundStatic = false;
    cout << "Static array (point on circle):" << endl;
    for (int i = 0; i < N; i++) {
        if (isPointOnCircle(p, staticArr[i])) {
            staticArr[i].print();
            foundStatic = true;
        }
    }
    if (!foundStatic)
        cout << "No circles found." << endl;

    cout << endl;

    bool foundDynamic = false;
    cout << "Dynamic array (point on circle):" << endl;
    for (int i = 0; i < N; i++) {
        if (isPointOnCircle(p, dynamicArr[i])) {
            dynamicArr[i].print();
            foundDynamic = true;
        }
    }
    if (!foundDynamic)
        cout << "No circles found." << endl;

    saveData("data.txt", staticArr, dynamicArr, N, p);

    delete[] dynamicArr;
    return 0;
}
