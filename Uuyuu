#define _CRT_SECURE_NO_WARNINGS
#include <iostream>
#include <cstring>

using namespace std;

class Date {
private:
    int day;
    int month;
    int year;

public:
    Date() {
        day = 1;
        month = 1;
        year = 2000;
    }

    Date(int d, int m, int y) {
        day = d;
        month = m;
        year = y;
    }

    ~Date() {
    }

    int getDay() const {
        return day;
    }

    int getMonth() const {
        return month;
    }

    int getYear() const {
        return year;
    }

    void setDay(int d) {
        day = d;
    }

    void setMonth(int m) {
        month = m;
    }

    void setYear(int y) {
        year = y;
    }

    friend istream& operator>>(istream& in, Date& d) {
        in >> d.day >> d.month >> d.year;
        return in;
    }

    friend ostream& operator<<(ostream& out, const Date& d) {
        out << d.day << "." << d.month << "." << d.year;
        return out;
    }
};

class Company {
private:
    char* companyName;
    Date dateOfEstablishment;

public:
    Company() {
        companyName = new char[1];
        companyName[0] = '\0';
    }

    Company(const char* name, const Date& d) {
        companyName = new char[strlen(name) + 1];
        strcpy(companyName, name);
        dateOfEstablishment = d;
    }

    Company(const Company& other) {
        companyName = new char[strlen(other.companyName) + 1];
        strcpy(companyName, other.companyName);
        dateOfEstablishment = other.dateOfEstablishment;
    }

    ~Company() {
        delete[] companyName;
    }

    Company& operator=(const Company& other) {
        if (this != &other) {
            delete[] companyName;
            companyName = new char[strlen(other.companyName) + 1];
            strcpy(companyName, other.companyName);
            dateOfEstablishment = other.dateOfEstablishment;
        }
        return *this;
    }

    char* getCompanyName() const {
        return companyName;
    }

    Date getDateOfEstablishment() const {
        return dateOfEstablishment;
    }

    void setCompanyName(const char* name) {
        delete[] companyName;
        companyName = new char[strlen(name) + 1];
        strcpy(companyName, name);
    }

    void setDateOfEstablishment(const Date& d) {
        dateOfEstablishment = d;
    }

    bool operator>=(const Company& other) const {
        return dateOfEstablishment.getYear() >= other.dateOfEstablishment.getYear();
    }

    friend istream& operator>>(istream& in, Company& c) {
        char buffer[100];
        in >> buffer;
        c.setCompanyName(buffer);
        in >> c.dateOfEstablishment;
        return in;
    }

    friend ostream& operator<<(ostream& out, const Company& c) {
        out << "Company name: " << c.companyName
            << ", Date of establishment: " << c.dateOfEstablishment;
        return out;
    }
};

int main() {
    int n;
    cout << "Enter number of companies: ";
    cin >> n;

    Company* arr = new Company[n];

    cout << "Enter companies (name day month year):" << endl;
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    Company key;
    cout << "Enter company for comparison (name day month year): ";
    cin >> key;

    cout << endl;
    cout << "Companies with year >= entered company year:" << endl;

    bool found = false;
    for (int i = 0; i < n; i++) {
        if (arr[i] >= key) {
            cout << arr[i] << endl;
            found = true;
        }
    }

    if (!found) {
        cout << "No matching companies." << endl;
    }

    delete[] arr;
    return 0;
}
