while (true)
{
    cout << "Enter cost: ";

    if (!(in >> l.cost)) // إذا كتب حرف بدل رقم
    {
        cout << "Error: cost must be a number!\n";
        in.clear(); // إزالة حالة الخطأ
        in.ignore(1000, '\n'); // حذف الإدخال الخطأ
        continue;
    }

    if (l.cost <= 0)
    {
        cout << "Error: cost must be greater than 0!\n";
        continue;
    }

    break;
}
