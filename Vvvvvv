#define _CRT_SECURE_NO_WARNINGS
#include <iostream>
#include <cstring>

using namespace std;

class Date {
private:
    int day;
    int month;
    int year;

public:
    Date() {
        day = 1;
        month = 1;
        year = 2000;
    }

    Date(int d, int m, int y) {
        setDay(d);
        setMonth(m);
        setYear(y);
    }

    ~Date() {}

    int getYear() const { return year; }

    void setDay(int d) {
        if (d >= 1 && d <= 31)
            day = d;
        else
            day = 1;
    }

    void setMonth(int m) {
        if (m >= 1 && m <= 12)
            month = m;
        else
            month = 1;
    }

    void setYear(int y) {
        if (y > 0)
            year = y;
        else
            year = 2000;
    }

    friend istream& operator>>(istream& in, Date& d) {
        do {
            in >> d.day >> d.month >> d.year;
            if (d.day < 1 || d.day > 31 ||
                d.month < 1 || d.month > 12 ||
                d.year <= 0) {
                cout << "Invalid date. Enter again: ";
            }
        } while (d.day < 1 || d.day > 31 ||
                 d.month < 1 || d.month > 12 ||
                 d.year <= 0);
        return in;
    }

    friend ostream& operator<<(ostream& out, const Date& d) {
        out << d.day << "." << d.month << "." << d.year;
        return out;
    }
};

class Company {
private:
    char* companyName;
    Date dateOfEstablishment;

public:
    Company() {
        companyName = new char[1];
        companyName[0] = '\0';
    }

    Company(const char* name, const Date& d) {
        companyName = new char[strlen(name) + 1];
        strcpy(companyName, name);
        dateOfEstablishment = d;
    }

    Company(const Company& other) {
        companyName = new char[strlen(other.companyName) + 1];
        strcpy(companyName, other.companyName);
        dateOfEstablishment = other.dateOfEstablishment;
    }

    ~Company() {
        delete[] companyName;
    }

    Company& operator=(const Company& other) {
        if (this != &other) {
            delete[] companyName;
            companyName = new char[strlen(other.companyName) + 1];
            strcpy(companyName, other.companyName);
            dateOfEstablishment = other.dateOfEstablishment;
        }
        return *this;
    }

    bool operator>=(const Company& other) const {
        return dateOfEstablishment.getYear() >= other.dateOfEstablishment.getYear();
    }

    friend istream& operator>>(istream& in, Company& c) {
        char buffer[100];

        do {
            in >> buffer;
            if (strlen(buffer) == 0)
                cout << "Invalid name. Enter again: ";
        } while (strlen(buffer) == 0);

        delete[] c.companyName;
        c.companyName = new char[strlen(buffer) + 1];
        strcpy(c.companyName, buffer);

        in >> c.dateOfEstablishment;

        return in;
    }

    friend ostream& operator<<(ostream& out, const Company& c) {
        out << "Company: " << c.companyName
            << ", Date: " << c.dateOfEstablishment;
        return out;
    }
};

int main() {
    int n;
    cout << "Enter number of companies: ";
    cin >> n;

    while (n <= 0) {
        cout << "Invalid number. Enter again: ";
        cin >> n;
    }

    Company* arr = new Company[n];

    cout << "Enter companies (name day month year):" << endl;
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    Company key;
    cout << "Enter company for comparison (name day month year): ";
    cin >> key;

    cout << "\nResult:\n";

    bool found = false;
    for (int i = 0; i < n; i++) {
        if (arr[i] >= key) {
            cout << arr[i] << endl;
            found = true;
        }
    }

    if (!found) {
        cout << "No matching companies." << endl;
    }

    delete[] arr;
    return 0;
}
